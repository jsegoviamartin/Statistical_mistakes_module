    {
      "cell_type": "code",
      "source": [
        "# Plot points\n",
        "plot(x, y,\n",
        "     col = ifelse(group == \"A\", \"blue\", \"red\"),\n",
        "     pch = 19,\n",
        "     xlab = \"Motivation (X)\",\n",
        "     ylab = \"Performance (Y)\",\n",
        "     main = \"Relationship between X and Y by Group\")\n",
        "\n",
        "# Add regression lines separately\n",
        "abline(lm(yA ~ xA), col = \"blue\", lwd = 2)\n",
        "abline(lm(yB ~ xB), col = \"red\", lwd = 2)\n",
        "\n",
