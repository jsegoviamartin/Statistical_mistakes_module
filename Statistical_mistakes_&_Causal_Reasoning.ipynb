    },
    {
      "cell_type": "markdown",
      "source": [
        "**Step 3 — Directly compare the two slopes**"
      ],
      "metadata": {
        "id": "apE18xnb8DpU"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "group <- rep(c(\"A\",\"B\"), each = n)\n",
        "x <- c(xA, xB)\n",
        "y <- c(yA, yB)\n",
        "\n",
        "model <- lm(y ~ x * group)\n",
        "summary(model)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 329
        },
        "id": "1gfi5hW37nZR",
